# ─────────────────────────────────────────────────────────────────────────────
# Dynamic Dashboard MCP server — configuration
# Copy this file to `.env` and fill in the secrets. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=3101
# Base URL used to build tokenized tile URLs. For standalone/local testing the
# default (http://localhost:PORT) is fine; set your real host once deployed.
PUBLIC_BASE_URL=http://localhost:3101
# Long-lived capability token guarding GET /dashboard and DELETE /tiles/*.
# Any unguessable string for the demo.
DASHBOARD_KEY=change-me-dashboard-key

# --- OpenAI (visualization generation) ---
# Your OpenAI.com API key (sk-...).
OPENAI_API_KEY=
# Model id used to generate the chart HTML/SQL. Strong models give better charts.
OPENAI_MODEL=gpt-4o

# --- Dataverse (confidential client / service principal) ---
# Target environment org URL (no trailing slash needed). Replace with your own
# environment's URL (Power Platform admin center -> Environments -> Environment URL).
DATAVERSE_ORG_URL=https://yourorg.crm4.dynamics.com
# App registration credentials (confidential client). Fill these in.
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=
# Data path: `tds` (SQL endpoint, default) or `webapi` (OData fallback).
DATA_PATH=tds
# TDS endpoint port (5558 or 1433). Leave default unless your network requires 1433.
DATAVERSE_TDS_PORT=5558

# --- Tile framing (CSP frame-ancestors) ---
# Which origins may iframe tiles. Add your PCF harness origin (default npm start =
# http://localhost:8181) while developing; lock to the org host once deployed.
# Space-separated CSP sources. Default if unset: "https://*.dynamics.com 'self'".
TILE_FRAME_ANCESTORS=https://*.dynamics.com http://localhost:8181 'self'

# --- State & logging ---
STATE_FILE=state.json
LOG_LEVEL=info
LOG_DIR=logs
