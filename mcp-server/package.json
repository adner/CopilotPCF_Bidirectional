{
  "name": "ddb-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dynamic Dashboard MCP server — NL → Dataverse-backed visualization, served as an MCP App widget and an embeddable tile.",
  "scripts": {
    "serve": "tsx main.ts",
    "serve:stdio": "tsx main.ts --stdio",
    "dev": "concurrently -k \"vite build --watch\" \"tsx watch main.ts\"",
    "build": "vite build",
    "probe": "tsx probe.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mssql": "^11.0.1",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
